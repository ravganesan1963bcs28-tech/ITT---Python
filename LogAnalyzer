import re
class LogAnalyzer:
    def __init__(self, filename):
        self.filename = filename
        self.error_logs = []
    def extract_errors(self):
        pattern = r'^ERROR \d{2}:\d{2}:\d{2}.*'
        try:
            with open(self.filename, 'r') as file:
                for line in file:
                    if re.match(pattern, line):
                        self.error_logs.append(line.strip())
        except FileNotFoundError:
            print("Log file not found.")
    def display(self):
        if self.error_logs:
            for log in self.error_logs:
                print(log)
        else:
            print("No matching ERROR logs found.")
with open("system.log", "w") as f:
    f.write("INFO 12:00:00 Started\n")
    f.write("ERROR 12:05:10 Failed to connect\n")
    f.write("DEBUG 12:06:00 Retrying\n")
    f.write("ERROR 12:07:15 Timeout reached\n")
analyzer = LogAnalyzer("system.log")
analyzer.extract_errors()
analyzer.display()
