
import re

class PasswordValidator:
    def __init__(self, password):
        self.password = password
        self.errors = []

    def validate(self):

        if len(self.password) < 8:
            self.errors.append("At least 8 characters")
        if not re.search(r'[A-Z]', self.password):
            self.errors.append("At least 1 uppercase letter")
        if not re.search(r'[a-z]', self.password):
            self.errors.append("At least 1 lowercase letter")
        if not re.search(r'\d', self.password):
            self.errors.append("At least 1 digit")
        if not re.search(r'[@#$%]', self.password):
            self.errors.append("At least 1 special character (@#$%)")

    def display_result(self):
        if not self.errors:
            print("Password is Valid")
        else:
            print("Invalid Password. Requirements missing:")
            for error in self.errors:
                print(f"- {error}")

pwd_input = input("Enter password to validate: ")
validator = PasswordValidator(pwd_input)
validator.validate()
validator.display_result()
